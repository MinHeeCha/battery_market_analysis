# ============================================================================
# AI Agent 기반 배터리 시장 전략 보고서 시스템
# 환경변수 설정 파일 (이 파일을 .env로 복사하여 실제 값 입력)
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# LLM 설정 (OpenAI)
# ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ─────────────────────────────────────────────────────────────────────────
# RAG (검색) 설정
# ─────────────────────────────────────────────────────────────────────────
# Embedding Model: BAAI/bge-m3 (open-source, multilingual, local inference)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # 또는 'cuda' (GPU), 'mps' (Apple Silicon)
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=./data/vector_store
MAX_SEARCH_RESULTS=5
USE_WEB_SEARCH=false

# 웹 검색을 사용할 경우 (선택사항)
# SEARCH_API_KEY=your-search-api-key
# SEARCH_ENGINE_TYPE=google  # or bing, duckduckgo

# ─────────────────────────────────────────────────────────────────────────
# 경로 설정
# ─────────────────────────────────────────────────────────────────────────
DATA_DIR=./data
OUTPUT_DIR=./outputs

# ─────────────────────────────────────────────────────────────────────────
# 실행 설정
# ─────────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=2
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# 데이터베이스 설정 (선택사항)
# ─────────────────────────────────────────────────────────────────────────
# Pinecone 사용 시
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=your-environment
# PINECONE_INDEX_NAME=battery-analysis

# ─────────────────────────────────────────────────────────────────────────
# 프록시 설정 (필요한 경우)
# ─────────────────────────────────────────────────────────────────────────
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8443
